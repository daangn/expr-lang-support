# FLEAMARKET_ARTICLE
if CANDIDATE_TYPE == candidate_type('FLEAMARKET_ARTICLE') { 1 } else { 0 }

# Service weight
* 0.735

# Engagement scores
* (
  3.24102 * Q_VALUE_FLEAMARKET_ARTICLE
  + 9.91502 * P_IMPRESSION_TO_WATCH_FLEAMARKET_ARTICLE
  + 106.66395 * P_IMPRESSION_TO_CHAT_FLEAMARKET_ARTICLE
  - 83.91478 * P_IMPRESSION_TO_HIDE_FLEAMARKET_ARTICLE
  - 12.67331 * P_IMPRESSION_TO_REPORT_FLEAMARKET_ARTICLE
)

# Decay scores
* (
  (
    # Impression count decay
    (if IMPRESSION_COUNT_FLEAMARKET_ARTICLE >= 1 { 0.01 } else { 1 })

    # Age seconds decay (max_age = 6hrs)
    * exp(-0.7 * min(21600.0, max(0, CURRENT_TIMESTAMP_SEC - EXAMPLE_PUBLISHED_AT_SEC)) / 21600.0)

    # Report count decay
    * exp(-0.14 * min(REPORT_COUNT_FLEAMARKET_ARTICLE, 5))

    # Operation score decay
    * (if OPERATION_SCORE_FLEAMARKET_ARTICLE >= 0.35 {
      exp(-4.0 * (OPERATION_SCORE_FLEAMARKET_ARTICLE - 0.35) / 0.65)
    } else {
      1
    })

    # Hide keyword seconds decay
    * (if EXAMPLE_HIDE_KEYWORD_AGE_SEC == -1 {
      1
    } else {
      min(1.0, (exp(1.0 * min(2419200.0, EXAMPLE_HIDE_KEYWORD_AGE_SEC) / 2419200.0) - 1) / (exp(1.0) - 1))
    })

    # Distance decay + Higher FleaMarket Service weight boost
    * (if CTX_REGION_RANGE_NO == 1 {
      (if EXAMPLE_DISTANCE_METER_FROM_USER_ESTIMATED_COORDINATE >= 0 {
        max(0.00001, exp(-2.0 * min(1.0, (EXAMPLE_DISTANCE_METER_FROM_USER_ESTIMATED_COORDINATE / 4000.0)))) * 1.2
      } else {
        1.0
      })
    } else {
      1.0
    })
  )

  # If score is lower than 0, change decay to boost
  ** (if (
    3.24102 * Q_VALUE_FLEAMARKET_ARTICLE
    + 9.91502 * P_IMPRESSION_TO_WATCH_FLEAMARKET_ARTICLE
    + 106.66395 * P_IMPRESSION_TO_CHAT_FLEAMARKET_ARTICLE
    - 83.91478 * P_IMPRESSION_TO_HIDE_FLEAMARKET_ARTICLE
    - 12.67331 * P_IMPRESSION_TO_REPORT_FLEAMARKET_ARTICLE
  ) > 0.0 {
    1
  } else {
    -1
  })
)
